# Copy to `.env` in the repo root (gitignored). Used by Docker Compose `env_file` for
# agate-api, core-api, and worker (paths in infra/docker-compose.yml). Core API receives
# DATABASE_URL / BACKFIELD_DATABASE_URL from compose for DB-backed login and credentials.

# Optional (local/demo/CI only): create the first org admin on core-api startup when the DB
# has no users. Do not enable in production. Requires email + password (or password file).
# BACKFIELD_BOOTSTRAP_ADMIN_FROM_ENV=1
# BACKFIELD_BOOTSTRAP_ADMIN_EMAIL=you@example.com
# BACKFIELD_BOOTSTRAP_ADMIN_PASSWORD=
# Or: BACKFIELD_BOOTSTRAP_ADMIN_PASSWORD_FILE=/run/secrets/bootstrap_admin_password
# BACKFIELD_BOOTSTRAP_ADMIN_DISPLAY_NAME=
# BACKFIELD_BOOTSTRAP_ADMIN_STRICT=1

# Optional: disable DB sync + starter graph creation on agate-api startup (default is on in compose).
# BACKFIELD_LOCAL_BOOTSTRAP=0

# Optional: disable deterministic canonical autolink gates during DBOutput ingest (default on).
# BACKFIELD_STRICT_CANONICAL_GATES=0

# Fernet key (URL-safe base64) for encrypting project secrets and organization integration secrets.
# Required by core-api (credentials UI), agate-api, and worker. Compose supplies a shared dev default per service
# when unset; override with one key for production: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MASTER_ENCRYPTION_KEY=

# Required for PlaceExtract + real GeocodeAgent runs (set at least one).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Optional geocoding / search providers.
# PELIAS_API_KEY=
# GEOCODIO_API_KEY=
# BRAVE_SEARCH_API_KEY=

# Mapbox (GeocodeAgent / UI map visualizations; same key name as project settings).
# MAPBOX_API_TOKEN=

# Optional: AWS for S3 Input (mirrored into General project secrets when BACKFIELD_LOCAL_BOOTSTRAP=1).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional: Agate Celery worker pool size for parallel node/S3 batch tasks (Compose only; default 8).
# CELERY_WORKER_CONCURRENCY=16

# Optional: shared service Bearer token (matches compose `SERVICE_API_TOKEN` / `x-shared-env`).
# SERVICE_API_TOKEN=

# Session cookie signing (Core API and any app that verifies `session`). Compose sets a dev default.
# SESSION_SECRET=

# Golden-path smoke (`make smoke`): session-shaped run (Core login → workspaces → Agate).
# Optional; omit to use service Bearer on Agate only. Loaded from this file by tests/smoke/golden_path_stack.py.
# SMOKE_EMAIL=
# SMOKE_PASSWORD=
# SMOKE_WORKSPACE_SLUG=default
# SMOKE_PROJECT_SLUG=general
# SMOKE_BOOTSTRAP=0
# SMOKE_AGATE_BEARER=
