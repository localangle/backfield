# Copy to `.env` in the repo root (gitignored). Used by Docker Compose `env_file` for
# agate-api and worker (paths in infra/docker-compose.yml). Core API receives
# DATABASE_URL / BACKFIELD_DATABASE_URL from compose for DB-backed login and credentials.

# Optional: disable DB sync + starter graph creation on agate-api startup (default is on in compose).
# BACKFIELD_LOCAL_BOOTSTRAP=0

# Fernet key for encrypting backfield_project_secret (compose provides a dev default if unset).
# MASTER_ENCRYPTION_KEY=

# Required for PlaceExtract + real GeocodeAgent runs (set at least one).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional geocoding / search providers.
# PELIAS_API_KEY=
# GEOCODIO_API_KEY=
# BRAVE_SEARCH_API_KEY=

# Mapbox (GeocodeAgent / UI map visualizations; same key name as project settings).
# MAPBOX_API_TOKEN=

# Optional: shared service Bearer token (matches compose `SERVICE_API_TOKEN` / `x-shared-env`).
# SERVICE_API_TOKEN=

# Session cookie signing (Core API and any app that verifies `session`). Compose sets a dev default.
# SESSION_SECRET=
