# Copy to `.env` in the repository root (gitignored). Docker Compose loads it into
# Agate API, Core API, Stylebook API, and the worker.
#
# `backfield init` creates this file and generates MASTER_ENCRYPTION_KEY and
# SESSION_SECRET when they are missing. Configure AI models, geocoding, search, and
# flow S3 credentials in Settings instead of adding provider API keys here.

# Shared local secrets

# Fernet key used to encrypt project and organization integration secrets.
# Generated by `backfield init`.
# MASTER_ENCRYPTION_KEY=

# Session-cookie signing key shared by all services that verify browser sessions.
# Generated by `backfield init`.
# SESSION_SECRET=

# Optional service-to-service Bearer token override. Compose uses `backfield-dev`
# locally when this is unset.
# SERVICE_API_TOKEN=

# Local stack behavior

# Disable creation of the default organization, workspace, and General project.
# Compose default: 1.
# BACKFIELD_LOCAL_BOOTSTRAP=0

# Disable additional deterministic canonical-link safeguards for diagnosis only.
# Default: enabled.
# BACKFIELD_STRICT_CANONICAL_GATES=0

# Run ready graph branches concurrently within each processed item.
# Compose worker default: 1.
# BACKFIELD_PARALLEL_GRAPH_LEVELS=1

# Worker process and database-pool sizing.
# CELERY_WORKER_CONCURRENCY=16
# WORKER_BACKFIELD_SQLALCHEMY_POOL_SIZE=1
# WORKER_BACKFIELD_SQLALCHEMY_MAX_OVERFLOW=0

# Optional Overpass operator settings for intersection and roadway geocoding.
# Compose defaults to 4 concurrent requests with a 0.5-second stagger.
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# OVERPASS_MIRROR_URLS=https://lz4.overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
# OVERPASS_MAX_CONCURRENT=4
# OVERPASS_QUERY_STAGGER_S=0.5
# OVERPASS_USER_AGENT=Backfield local development

# Stylebook bundle storage
#
# Bundle import/export is platform infrastructure, not a project integration.
# Routes return 503 until a bucket is configured. AWS credentials are optional
# when the local environment already provides a usable credential chain.

# STYLEBOOK_BUNDLE_S3_BUCKET=
# STYLEBOOK_BUNDLE_S3_PREFIX=stylebook-bundles
# AWS_S3_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Smoke tests
#
# Session credentials are optional; without them, `make smoke` uses service auth.
# See docs/development/testing.md for polling and data-retention controls.

# SMOKE_EMAIL=
# SMOKE_PASSWORD=
# SMOKE_WORKSPACE_SLUG=default
# SMOKE_PROJECT_SLUG=general
# SMOKE_AGATE_BEARER=
